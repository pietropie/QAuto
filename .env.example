# Copie este arquivo para .env e preencha os valores
# No Coolify, configure estas variaveis em Environment Variables

# URL da aplicacao que sera testada
APP_BASE_URL=https://sua-app.com.br

# Credenciais de teste (use um usuario dedicado para QA)
APP_USERNAME=qa@suaempresa.com
APP_PASSWORD=senha-de-teste

# Chave da API da OpenAI para analise visual com IA (GPT-4o mini)
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Porta da API (padrao: 8000)
PORT=8000

# Ambiente (production ou development)
ENV=production

# URL do Redis (nao precisa mudar se usar o docker-compose)
REDIS_URL=redis://redis:6379/0
