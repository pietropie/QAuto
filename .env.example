# Copie este arquivo para .env e preencha os valores
# No Coolify, configure estas variáveis em Environment Variables

# URL da aplicação que será testada (fallback se não configurar apps pelo painel)
APP_BASE_URL=https://sua-app.com.br

# Credenciais de teste (fallback — prefira configurar pelo painel)
APP_USERNAME=
APP_PASSWORD=

# Chave da OpenAI (fallback — prefira configurar pelo painel em Config IA)
OPENAI_API_KEY=sk-...

# Chave secreta para assinar tokens JWT (mude para algo seguro em produção!)
SECRET_KEY=mude-isso-para-algo-secreto-em-producao-32chars

# Porta da API (padrão: 8000)
PORT=8000

# Ambiente
ENV=production

# URL do Redis (não precisa mudar se usar o docker-compose)
REDIS_URL=redis://qauto-redis:6379/0
